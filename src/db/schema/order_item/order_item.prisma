model Order_Item {
    id      String @id @default(uuid())
    orderId String
    order   Order  @relation(fields: [orderId], references: [id])

    meal_id String
    meal    Meal   @relation(fields: [meal_id], references: [id])

    quantity Int
    price    Decimal @db.Decimal(10, 2)

    @@map("order_items")
}
