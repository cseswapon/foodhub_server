model User {
  id            String     @id
  name          String
  email         String
  emailVerified Boolean    @default(false)
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  role          UserRole   @default(customer)
  phone         String
  address       String?
  status        UserStatus @default(active)
  sessions      Session[]
  accounts      Account[]
  provider      Provider?
  orders        Order[]
  reviews       Review[]

  @@unique([email])
  @@map("users")
}
