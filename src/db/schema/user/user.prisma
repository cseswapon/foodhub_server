model User {
  id            String     @id
  name          String
  email         String
  emailVerified Boolean    @default(false)
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  role          UserRole   @default(customer)
  phone         String
  address       String?
  status        UserStatus @default(activate)
  sessions      Session[]
  accounts      Account[]
  provider      Provider[]
  orders        Order[]
  reviews       Review[]
  meals         Meal[]

  @@unique([email])
  @@index([role], name: "idx_user_role")
  @@index([status], name: "idx_user_status")
  @@index([email], name: "idx_user_email")
  @@map("users")
}
