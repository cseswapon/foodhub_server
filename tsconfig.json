{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",

    "strict": true,
    "esModuleInterop": true,

    "lib": ["esnext"],
    "types": ["node"],

    "declaration": false,

    "isolatedModules": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax":false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "prisma.config.ts"]
}
